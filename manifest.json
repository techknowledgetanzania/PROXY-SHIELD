{
  "manifest_version": 3,
  "name": "ProxyShield",
  "version": "1.0.0",
  "description": "Advanced proxy manager with DNS leak prevention. Supports HTTP, HTTPS, SOCKS4, and SOCKS5 proxies.",
  "permissions": [
    "proxy",
    "storage",
    "privacy",
    "webRequest",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options.html"
}
